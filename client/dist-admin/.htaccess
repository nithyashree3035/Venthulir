# ================================================================
# Venthulir — Hostinger Production .htaccess
# ================================================================

# --- HTTPS Redirect ---
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Remove www (canonical) ---
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# --- React SPA Fallback (all routes → index.html) ---
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(?!admin/)(.*)$ /index.html [L]

# Admin SPA Fallback
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^admin/(.*)$ /admin/index.html [L]

# --- GZIP / Brotli Compression ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>

# --- Browser Caching (Long-term for hashed assets) ---
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML - short (app may update)
  ExpiresByType text/html                 "access plus 1 hour"

  # CSS & JS (hashed filenames — safe to cache forever)
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType text/javascript           "access plus 1 year"

  # Images — 30 days
  ExpiresByType image/png                 "access plus 30 days"
  ExpiresByType image/jpg                 "access plus 30 days"
  ExpiresByType image/jpeg                "access plus 30 days"
  ExpiresByType image/webp                "access plus 30 days"
  ExpiresByType image/svg+xml             "access plus 30 days"
  ExpiresByType image/x-icon              "access plus 1 year"

  # Fonts
  ExpiresByType font/woff                 "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType application/font-woff     "access plus 1 year"
</IfModule>

# --- Cache-Control Headers ---
<IfModule mod_headers.c>
  # Hashed CSS/JS → immutable
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images → 30 days
  <FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=2592000, stale-while-revalidate=86400"
  </FilesMatch>

  # Fonts → 1 year
  <FilesMatch "\.(woff|woff2|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML → no-cache (always fresh)
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>

  # Security Headers
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# --- Keep-Alive ---
<IfModule mod_headers.c>
  Header set Connection keep-alive
</IfModule>

# --- Serve Correct MIME Types ---
AddType application/javascript .js .mjs
AddType image/webp .webp
AddType font/woff2 .woff2
